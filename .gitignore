# Rust build artifacts
/target/

# IDE and Editor configurations
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# RustyClaw local runtime configurations & state
/config.json
/.security.yml
/memory.db
/memory.db-journal
/memory.db-wal
/memory.db-shm
/workspace/memory.db
/workspace/memory.db-journal
/workspace/memory.db-wal
/workspace/memory.db-shm

# Tantivy search index (generated at runtime)
/workspace/memory/index/

# Dynamic runtime logs and generated digests
/workspace/memory/heartbeat-state.json
/workspace/memory/heartbeat-digest.md
/workspace/memory/logs/
/workspace/memory/summaries/
/workspace/memory/debug/
/workspace/sessions/

# Temporary and backup files
*.tmp
*.bak
tempfile*

# Antigravity CLI metadata
.antigravitycli/

# ── Production (RPi4) deploy dir: ローカル設定・シークレット・バイナリ・ランタイムデータ ──
# シークレット vault（絶対にコミットしない）
/production/config/vault.enc
/production/config/*.enc
# アクティブ profile の symlink（debug/release のどちらを指すかはローカル運用判断・追跡しない）
/production/config/config.json
# クロスビルド成果物（大容量バイナリ）
/production/bin/
/production/neuron_usage.json
# 本番ワークスペースのランタイム生成物（DB・索引・ログ・要約・セッション）
/production/workspace/memory.db
/production/workspace/memory.db-journal
/production/workspace/memory.db-wal
/production/workspace/memory.db-shm
/production/workspace/memory/index/
/production/workspace/memory/heartbeat-state.json
/production/workspace/memory/heartbeat-digest.md
/production/workspace/memory/logs/
/production/workspace/memory/summaries/
/production/workspace/memory/debug/
/production/workspace/sessions/

# ローカル開発用設定ディレクトリ（$vault 参照・各種 ID を含むため追跡しない）
/config/

# crate ディレクトリ起点で実行/テストした際に生成される debug-dump 残骸（cruft）
/crates/*/workspace/

# 本番ランタイム生成物の追加分（デプロイログ・自発投稿バッファ）
/production/logs/
/production/workspace/memory/proactive-posts.md

.worktrees/
/production/fastembed_cache/
